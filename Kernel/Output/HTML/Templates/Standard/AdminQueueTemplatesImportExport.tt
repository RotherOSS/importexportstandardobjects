<div class="MainBox ARIARoleMain LayoutFixedSidebar SidebarFirst">

    [%
        SET Type  = Translate(Data.Type);
        SET Label = Translate("Queue Template Relations");
    %]

    [% BreadcrumbPath = [
            {
                Name => Translate("%s - %s",Label, Type),
            },
        ]
    %]

    [% INCLUDE "Breadcrumb.tt" Path = BreadcrumbPath %]
    <div class="Clear"></div>

    <div class="SidebarColumn">
        <div class="WidgetSimple">
            <div class="Header">
                <h2>[% Translate("Actions") | html %]</h2>
            </div>
            <div class="Content">
                <ul class="ActionList">
[% RenderBlockStart("ActionOverview") %]
                    <li>
                        <a href="[% Env("Baselink") %]Action=AdminQueueTemplates" class="CallForAction Fullsize Center">
                        <span><i class="fa fa-plus-square"></i>[% Translate("Queue Template Relations") | html %]</span></a>
                    </li>
[% RenderBlockEnd("ActionOverview") %]
                </ul>
            </div>
        </div>

        <div class="WidgetSimple">
            <div class="Header">
                <h2>[% Translate("Hint") | html %] - [% Translate(Data.Type) | html %]</h2>
            </div>
            <div class="Content">
                <div class="FieldExplanation">
                    <p>
                        <b>
                            [% Translate("Select the items you want to ") | html %] [% Translate(Data.Type) | html %].
                        </b>

                        <p>
                            </br>
[% RenderBlockStart("ImportHint") %]
                        [% Translate("Select the desired elements and confirm the import with 'import'.") | html %]
[% RenderBlockEnd("ImportHint") %]
[% RenderBlockStart("ExportHint") %]
                        [% Translate("Here you can export a configuration file of queue-template relations to import these on another system. The configuration file is exported in yml format.") | html %]
[% RenderBlockEnd("ExportHint") %]
                         </p>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="ContentColumn">
        <div class="WidgetSimple">
            <div class="Header">
                <h2>[% Translate("Queues List") | html %]</h2>
            </div>
            <div class="Clear"></div>
            <div class="Content LayoutGrid ColumnsWithSpacing">

                <form id='Form' action="[% Env("CGIHandle") %]" method="post" class="Validate PreventMultipleSubmits">
                    <input type="hidden" name="Action" value="[% Env("Action") %]"/>
                    <input type="hidden" name="Subaction" value="[% Env("Subaction") %]Action"/>
                    <input type="hidden" name="Type" value="[% Data.Type | html %]"/>
                    <input type="hidden" name="OverwriteExistingEntities"  value="[% Data.OverwriteExistingEntities | html %]">
                    <table class="DataTable" id="QueuesTable" summary="List of all registered Queues">
                        <thead>
                            <tr>
                                <th class='Center'>
                                    <input type="checkbox" name="SelectAllQueues" title="[% Translate('Toggle all available elements') | html %]" checked value="" />
                                    [% Translate("Fields") | html %]
                                </th>
                                <th>[% Translate("Name") | html %]</th>
                            </tr>
                        </thead>
                        <tbody>
[% RenderBlockStart("QueuesRow") %]
                            <tr id="QueueID_[% Data.QueueID | html %]">
                                <td class='Center'>
[% RenderBlockStart("QueueCheckbox") %]
                                    <input type="checkbox" id="Queues" name="Queues" value="[% Data.Name | html %]" checked />
[% RenderBlockEnd("QueueCheckbox") %]
                                </td>
                                <td>
[% RenderBlockStart("Import") %]
                                    [% Data.Name %]
[% RenderBlockEnd("Import") %]
[% RenderBlockStart("Export") %]
                                    <a href="[% Env("Baselink") %]Action=AdminQueueTemplates;Subaction=Change;QueueID=[% Data.QueueID | uri %]" title="[% Data.Name | html %]" class="MasterActionLink">[% Data.Name %]</a>
[% RenderBlockEnd("Export") %]
                                </td>
                            </tr>
[% RenderBlockEnd("QueuesRow") %]
                        </tbody>
                    </table>
                    <div class="Field SpacingTop" style="text-align: center;">
                        <button class="Primary CallForAction" type="submit" id="Export" value="[% Translate(Data.Type) | html %]">
                            <span>[% Translate(Data.Type) | html %]</span>
                        </button>
                        [% Translate("or") | html %]
                        <a href="[% Env("Baselink") %]Action=AdminQueueTemplates" >[% Translate("Cancel") | html %]</a>
                    </div>
                    <div class="Clear"></div>
                </form>
            </div>
        </div>
        <div class="Clear"></div>
    </div>
</div>
